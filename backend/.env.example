# ── General ───────────────────────────────────────────────────────────────────
ENV=development

# ── API Keys (REQUIRED) ───────────────────────────────────────────────────────
# OpenAI is required for embeddings regardless of which LLM you use for chat.
OPENAI_API_KEY=your_openai_api_key_here

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── LLM provider ──────────────────────────────────────────────────────────────
# "openai"    → uses gpt-4o-mini (fast, cheap, great quality)
# "anthropic" → uses claude-sonnet-4-6 (very strong reasoning)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small

# ── Upload & vector store ─────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
COLLECTION_NAME=pdf_documents

# Storage paths (override for production / persistent disk)
# UPLOAD_DIR=/data/uploads
# CHROMA_DIR=/data/chroma

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=4

# ── CORS (production) ────────────────────────────────────────────────────────
# Set to your deployed URL to lock down CORS in production.
# Leave as "*" for local development.
# ALLOWED_ORIGINS=https://your-app.onrender.com
